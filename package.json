{
  "name": "tracecue-agent",
  "version": "0.2.0",
  "private": true,
  "description": "TraceCue Agent: source-grounded, human-reviewed, replayable procedure guides.",
  "scripts": {
    "dev": "next dev",
    "dev:host": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm build && pnpm lint",
    "validate": "pnpm check"
  },
  "dependencies": {
    "@mantine/core": "latest",
    "@mantine/hooks": "latest",
    "@mantine/notifications": "latest",
    "@tabler/icons-react": "latest",
    "next": "16.2.10",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "typescript": "^5.9.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  }
}
